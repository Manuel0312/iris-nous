BCI_IOT_HOME_ASSISTANT_URL=
BCI_IOT_HOME_ASSISTANT_TOKEN=
BCI_IOT_SPOTIFY_CLIENT_ID=
BCI_IOT_SPOTIFY_CLIENT_SECRET=
BCI_IOT_SPOTIFY_REDIRECT_URI=http://127.0.0.1:8080/callback
